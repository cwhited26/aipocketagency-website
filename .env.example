# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  POCKET AGENT — MASTER ENV REFERENCE                                        ║
# ║                                                                            ║
# ║  This is the single source of truth for every environment variable the     ║
# ║  app reads. To run Pocket Agent IN PRODUCTION you must set everything       ║
# ║  marked `# REQUIRED`. Vars marked `# OPTIONAL` have sensible defaults       ║
# ║  baked into the code (or gate a feature OFF until set) — the app boots and  ║
# ║  runs without them; only the specific connector/feature stays dark.         ║
# ║                                                                            ║
# ║  Copy to `.env.local` for local dev; set the live values in the Vercel     ║
# ║  project env (all environments). Leave secrets blank here — never commit    ║
# ║  real keys. Sections are grouped by concern and sorted within each group.   ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Auth / public Supabase (bos-internal project, repointed by env in Vercel) ──
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Pocket Agent Supabase (dedicated PA project — separate from bos-internal CRM) ──
# When these are set they take precedence over NEXT_PUBLIC_SUPABASE_* for all
# Pocket Agent data access (pa-supabase, pa-conversations, pocket-agent-supabase,
# middleware subscription check, billing-portal route).  Leave unset to fall back
# to the existing chain (safe during the cutover rollout).
POCKET_AGENT_SUPABASE_URL=https://<pa-project>.supabase.co
POCKET_AGENT_SUPABASE_ANON_KEY=<pa-anon-key>
POCKET_AGENT_SUPABASE_SERVICE_KEY=<pa-service-role-key>

# ── CRM / leads Supabase (bos-internal — wc-admin-supabase.ts, do NOT repoint) ──
WC_ADMIN_SUPABASE_URL=https://<bos-internal>.supabase.co
WC_ADMIN_SUPABASE_SERVICE_KEY=<service-role-key>

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Pocket Agent recurring price (set explicitly as the checkout line item — NOT the
# product default_price). [2026-06-02 — repriced from $97/mo to $37/mo]
STRIPE_POCKET_AGENT_PRICE_ID=price_1TdyfmJ6S5nx9HK5EeAZQEPj

# ── OpenAI (Whisper speech-to-text for voice-memo capture) ──
# Used by POST /api/app/voice/transcribe to transcribe in-app voice memos via the
# whisper-1 audio/transcriptions endpoint (direct REST, no SDK). APA-provided key
# (not BYO) — set this in Vercel project env vars for all environments.
OPENAI_API_KEY=sk-...

# ── YouTube ingester (transcript + metadata for any YouTube URL on any inbound surface) ──
# YouTube Data API v3 key — fetches title/channel/duration/description/stats for an ingested
# video (GET /youtube/v3/videos, direct REST). OPTIONAL: when unset the ingester still pulls the
# transcript (timedtext, or the Whisper audio fallback) and writes the brain note from the video
# id; metadata is enrichment, not required. The captionless fallback uses OPENAI_API_KEY above.
# Provision (Chase): Google Cloud Console → create/select a project → APIs & Services → Library →
# enable "YouTube Data API v3" → Credentials → Create credentials → API key → restrict the key to
# the YouTube Data API v3 → paste below and set in Vercel project env vars for all environments.
YOUTUBE_API_KEY=

# ── Connections v1 — Gmail OAuth + 5-min cron sync ──
# Web OAuth client (Chase provisions in GCP console). Redirect URIs:
#   https://app.aipocketagency.com/api/connections/gmail/callback  (prod)
#   http://localhost:3000/api/connections/gmail/callback           (dev)
# Scopes: gmail.readonly + gmail.modify + gmail.labels (+ openid, email).
GMAIL_OAUTH_CLIENT_ID=<gmail-oauth-client-id>
GMAIL_OAUTH_CLIENT_SECRET=<gmail-oauth-client-secret>
# Single source of truth for the OAuth redirect_uri (lib/gmail.ts gmailRedirectUri()).
# MUST match a registered Authorized redirect URI origin in the GCP OAuth client, or
# Google fails the flow with "Error 400: redirect_uri_mismatch". Never derived from
# the request host (prod also answers on the apex + *.vercel.app aliases).
#   prod + dev (Vercel): https://app.aipocketagency.com
#   local:               http://localhost:3000
PA_OAUTH_REDIRECT_BASE=https://app.aipocketagency.com
# 32-byte base64 key encrypting stored Gmail refresh tokens (AES-256-GCM,
# lib/crypto/encrypt.ts). Generate fresh: openssl rand -base64 32
# REUSED by the Slack Connection to encrypt its stored tokens.
GMAIL_TOKEN_ENCRYPTION_KEY=<base64-32-bytes>

# ── Slack Connection (Connections Roadmap §2.1) ──
# Slack app OAuth credentials (Chase creates the Slack app at api.slack.com/apps).
# Redirect URL to register on the app:
#   https://app.aipocketagency.com/api/connections/slack/callback  (prod)
#   http://localhost:3000/api/connections/slack/callback           (dev)
# Bot scopes requested: channels:read channels:history groups:read groups:history
#   im:read im:history users:read chat:write chat:write.public chat:write.customize im:write
# Until these are set, the Connections card shows "Configure Slack OAuth in Vercel" (no crash).
SLACK_CLIENT_ID=<slack-client-id>
SLACK_CLIENT_SECRET=<slack-client-secret>
# Slack signing secret (request-signature verification for any future Slack inbound events).
SLACK_SIGNING_SECRET=<slack-signing-secret>
# Per-user-per-minute cap on Slack sends (abuse defense). Optional; defaults to 30.
PA_SLACK_MAX_SENDS_PER_MIN=30
# Shared secret the Vercel cron sends as `Authorization: Bearer`. Also gates
# /api/cron/routines + /api/cron/personas-digest. Generate: openssl rand -hex 32
CRON_SECRET=<cron-secret>

# ── Personas + Team (Wave 1 — Mode A internal team agents) ──
# Default + fallback chat models for personas (lib/personas chat + digest + knowledge
# extraction). Fallback is used only when the default model errors on a chat turn.
PA_PERSONAS_DEFAULT_MODEL=claude-sonnet-4-6
PA_PERSONAS_FALLBACK_MODEL=claude-haiku-4-5-20251001
# Apex origin used to build team-member chat + invite links (/persona/<token>,
# /personas/accept/<token>). MUST be the apex, NOT app.aipocketagency.com — the app
# subdomain rewrites /* to /app/* (vercel.json) and would break these root routes.
# Falls back to NEXT_PUBLIC_SITE_URL, then https://aipocketagency.com.
PA_PERSONAS_PUBLIC_BASE_URL=https://aipocketagency.com
# Optional. Promotes active subscribers above the default 'pro' tier until a Stripe
# price->tier mapping lands. One of: pro | pro_plus | studio | studio_plus | enterprise.
# PA_PERSONAS_DEFAULT_TIER=pro

# ── Personas Wave 2 — Modes B + C (public link + website widget) ──
# HARD GATE. Public + widget surfaces (/public-persona, /widget/<token>.js, the
# public-chat + widget-config APIs, and the owner Mode toggle) return 503 "coming soon"
# until this is the EXACT string "true". Flip ON only after the adversarial-testing gate
# (Pocket_Agent_Personas_Adversarial_Brief.md §8) clears. Default unset = OFF.
# PA_PERSONAS_PUBLIC_MODES_ENABLED=true
# Anonymous-traffic rate limits (server-side, atomic). Defaults shown.
# PA_PERSONAS_RATE_LIMIT_IP_PER_HOUR=60
# PA_PERSONAS_RATE_LIMIT_SESSION_PER_DAY=100
# PA_PERSONAS_RATE_LIMIT_PERSONA_PER_DAY=5000

# ── Dev GTM Wave 1 — BYO LLM provider system + Public REST API v1 ──
# 32-byte base64 key encrypting stored BYO LLM provider API keys (AES-256-GCM,
# lib/crypto/provider-key.ts). SEPARATE from GMAIL_TOKEN_ENCRYPTION_KEY for a clean
# key-rotation path. Generate fresh: openssl rand -base64 32 — drop on Vercel (Sensitive).
LLM_PROVIDER_KEY_ENCRYPTION_KEY=<base64-32-bytes>
# Public REST API per-key hourly burst caps (requests/hour). Daily caps are fixed in
# lib/api-keys/rate-limit.ts per SPEC §9.2 (free 1000/day, sync 10k, publish 100k).
PA_API_RATE_LIMIT_FREE_RPM=100
PA_API_RATE_LIMIT_SYNC_RPM=500
PA_API_RATE_LIMIT_PUBLISH_RPM=2000
# Optional. Promotes all API keys to a higher dev tier until the Sync/Publish Stripe
# price->tier mapping lands (Wave 3). One of: free | sync | publish | enterprise.
# PA_API_DEFAULT_TIER=free

# ═══════════════════════════════════════════════════════════════════════════
# OAUTH CLIENTS — per-connector OAuth app credentials. Each pair gates ONE
# connector: until both halves are set, that connector shows "configure" in
# the UI and stays off (no crash). All OPTIONAL — set the ones you ship.
# Redirect URIs follow PA_OAUTH_REDIRECT_BASE (see Connections block above).
# ═══════════════════════════════════════════════════════════════════════════

# Calendly connector OAuth (lib/connectors/calendly/oauth.ts) — schedule reads/writes.
CALENDLY_CLIENT_ID=                         # OPTIONAL
CALENDLY_CLIENT_SECRET=                      # OPTIONAL
# GitHub Build connector OAuth (lib/connectors/github-build/oauth.ts) — create-repo /
# push-files / open-PR. DISTINCT from the brain-read GitHub app (provider github_build).
GITHUB_BUILD_OAUTH_CLIENT_ID=               # OPTIONAL
GITHUB_BUILD_OAUTH_CLIENT_SECRET=           # OPTIONAL
# Google connector OAuth (api/app/connections/google/*) — Calendar/Drive access.
# Separate from the Gmail Connection client above (GMAIL_OAUTH_CLIENT_*).
GOOGLE_OAUTH_CLIENT_ID=                      # OPTIONAL
GOOGLE_OAUTH_CLIENT_SECRET=                  # OPTIONAL
# QuickBooks (Intuit) connector OAuth (lib/connectors/quickbooks/oauth.ts).
INTUIT_CLIENT_ID=                            # OPTIONAL
INTUIT_CLIENT_SECRET=                        # OPTIONAL
# Intuit API environment: "sandbox" (default) or "production".
INTUIT_ENVIRONMENT=                          # OPTIONAL — defaults to "sandbox"
# Stripe Connect client id (lib/connectors/stripe/oauth.ts) — lets an owner connect
# THEIR OWN Stripe account as a connector. Distinct from STRIPE_SECRET_KEY (our billing).
STRIPE_CONNECT_CLIENT_ID=                    # OPTIONAL
# Zoom connector OAuth (lib/connectors/zoom/oauth.ts) — meetings/recordings.
ZOOM_CLIENT_ID=                              # OPTIONAL
ZOOM_CLIENT_SECRET=                          # OPTIONAL

# ═══════════════════════════════════════════════════════════════════════════
# CONNECTORS — API keys / runtime creds for non-OAuth integrations.
# ═══════════════════════════════════════════════════════════════════════════

# Bright Data API key — Lead Scout web/SERP data (lib/leads/brightdata.ts,
# pa-lead-scout-connections.ts). Without it Lead Scout's live sources stay off.
BRIGHT_DATA_API_KEY=                         # OPTIONAL
# Bright Data Web Unlocker zone name.
BRIGHT_DATA_ZONE=                            # OPTIONAL — defaults to "web_unlocker1"
# Bright Data SERP zone name.
BRIGHT_DATA_SERP_ZONE=                       # OPTIONAL — defaults to "serp"
# Modal token pair — auth for the Modal-hosted RAG runtime AND the code-exec sandbox
# (lib/rag/client.ts, lib/connectors/modal-sandbox/client.ts).
MODAL_TOKEN_ID=                              # OPTIONAL
MODAL_TOKEN_SECRET=                          # OPTIONAL
# Moonchild design MCP — powers URL-import + design tokens in the Landing Page Builder
# (lib/connectors/moonchild/client.ts). Both required for the Moonchild features.
MOONCHILD_MCP_URL=                           # OPTIONAL
MOONCHILD_MCP_TOKEN=                         # OPTIONAL
# Recall.ai (Meeting Persona, MP-CORE-1) — the meeting-bot service that joins Zoom/Meet/Teams calls.
# The owner's Recall API key is pasted per-account and stored encrypted; the two keys below are the
# platform-level secrets the connector itself needs.
# AES-256-GCM key (base64, 32 bytes) encrypting each owner's stored Recall API key
# (lib/crypto/recall-key.ts). Required for the Meeting Persona connect/exec paths. Mint:
# openssl rand -base64 32
RECALL_API_KEY_ENCRYPTION_KEY=               # REQUIRED (for Meeting Persona)
# Recall.ai webhook signing secret (Svix `whsec_…`) — verifies POSTs to /api/webhooks/recall-ai.
# Copy it from the Recall.ai dashboard webhook/endpoint settings. Without it the webhook 500s.
RECALL_WEBHOOK_SECRET=                        # REQUIRED (for Meeting Persona)
# Recall.ai API base URL. Recall is region-partitioned; override only when the owner's Recall
# workspace is outside us-east-1 (e.g. https://eu-central-1.recall.ai/api/v1).
RECALL_API_BASE_URL=                          # OPTIONAL — defaults to https://us-east-1.recall.ai/api/v1
# AES-256-GCM key (base64, 32 bytes) encrypting each owner's stored Deepgram API key
# (lib/connectors/deepgram/key.ts) for Meeting Persona live transcription (MP-CORE-2). Required for
# the Deepgram connect/transcribe paths. Mint: openssl rand -base64 32
DEEPGRAM_API_KEY_ENCRYPTION_KEY=             # REQUIRED (for Meeting Persona)
# AES-256-GCM key (base64, 32 bytes) encrypting stored connector credentials in the
# PA vault (lib/pa-vault.ts). REQUIRED once any credential-storing connector is used —
# the vault throws without it. Generate: openssl rand -base64 32
PA_CONNECTIONS_ENC_KEY=                      # REQUIRED (for connectors)
# Resend API key — all transactional + onboarding/funnel email sends (lib/resend.ts,
# lib/email/resend.ts). Without it every send fails (welcome, receipts, drips).
RESEND_API_KEY=                              # REQUIRED
# Resend inbound webhook signing secret — verifies inbound-email POSTs
# (api/connectors/email/inbound). Required only if inbound email is enabled.
RESEND_INBOUND_SIGNING_SECRET=               # OPTIONAL
# Twilio SMS connector creds (lib/connectors/sms/config.ts). The PA_-prefixed pair is
# preferred; the unprefixed pair is the fallback. Set one pair to enable SMS. The same creds
# power Pocket Capture's per-user SMS capture surface (PC-CORE-3) — no extra vars needed.
PA_TWILIO_ACCOUNT_SID=                       # OPTIONAL
PA_TWILIO_AUTH_TOKEN=                        # OPTIONAL
TWILIO_ACCOUNT_SID=                          # OPTIONAL — fallback for PA_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=                           # OPTIONAL — fallback for PA_TWILIO_AUTH_TOKEN

# ── Voice Call channel (Channels Gateway Phase 6) ───────────────────────────────────────────
# Voice uses the UNPREFIXED Twilio pair above (TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN) for the
# account it provisions numbers under + signs webhooks with, plus the keys below. The Twilio Auth
# Token is stored AES-256-GCM-encrypted at rest on the connection (key GMAIL_TOKEN_ENCRYPTION_KEY,
# already required above). Voice also reuses OPENAI_API_KEY (Whisper STT) from the top of this file.
# The feature flag stays OFF until all of these are set and the test-call button passes end-to-end.
PA_VOICE_CALL_ENABLED=                        # OPTIONAL — "true" to enable; default OFF
ELEVENLABS_API_KEY=                           # OPTIONAL — ElevenLabs API key with streaming TTS access
TWILIO_SHARED_POOL_NUMBER=                    # OPTIONAL — E.164 shared-pool DID for lower-tier owners
# The wss:// origin of the standalone Twilio Media Stream service (Vercel can't host the socket).
# Defaults to the webhook base with scheme→wss + path /voice-stream if unset. See docs/voice-call/handoff.md.
PA_VOICE_STREAM_WSS_URL=                      # OPTIONAL — e.g. wss://voice.aipocketagent.com/voice-stream

# ═══════════════════════════════════════════════════════════════════════════
# ORCHESTRATOR / RUNTIME — endpoints + tokens for the out-of-process runtimes
# and the public base URL they call back into.
# ═══════════════════════════════════════════════════════════════════════════

# Orchestrator runtime base URL (lib/orchestrator/runtime-client.ts). Also the
# fallback base for deriving the Modal sandbox URL. Required if the orchestrator runs.
PA_ORCHESTRATOR_RUNTIME_URL=                 # OPTIONAL
# Shared bearer secret authenticating orchestrator runtime <-> app calls (both directions).
PA_ORCHESTRATOR_RUNTIME_TOKEN=               # OPTIONAL
# Public base URL the runtimes use to call back into the app (Mission Control links,
# webhooks). Falls back to https://$VERCEL_URL then the site origin.
PA_PUBLIC_URL=                               # OPTIONAL
# RAG runtime URL (Modal) — lib/rag/client.ts. Required for RAG retrieval to work.
PA_RAG_RUNTIME_URL=                          # OPTIONAL
# Modal sandbox runtime URL — lib/connectors/modal-sandbox/client.ts. If unset it is
# derived from PA_ORCHESTRATOR_RUNTIME_URL.
PA_SANDBOX_RUNTIME_URL=                      # OPTIONAL
# Vercel-injected deployment host (no scheme). Used as a callback-URL fallback when
# PA_PUBLIC_URL is unset. Vercel sets this automatically — no need to set by hand.
VERCEL_URL=                                  # OPTIONAL — auto-set by Vercel

# ═══════════════════════════════════════════════════════════════════════════
# RATE LIMITS / BUDGETS — per-minute write caps + per-run budgets. All numeric,
# all OPTIONAL with in-code defaults. Raise/lower per environment.
# ═══════════════════════════════════════════════════════════════════════════

# Orchestrator gate: max connector spend (USD) per run (gates/config.ts).
PA_GATE_CONNECTOR_BUDGET_USD=                # OPTIONAL
# Orchestrator gate: max wall-clock seconds per run (gates/config.ts).
PA_GATE_TIME_BUDGET_SEC=                     # OPTIONAL
# GitHub Build connector: max write actions per minute (actions.ts).
PA_GITHUB_BUILD_MAX_WRITES_PER_MIN=          # OPTIONAL
# Orchestrator: default per-run time budget in seconds (feature-flag.ts).
PA_ORCHESTRATOR_DEFAULT_TIME_BUDGET_SEC=     # OPTIONAL
# Orchestrator: max concurrent runs per user (feature-flag.ts).
PA_ORCHESTRATOR_MAX_CONCURRENT_RUNS_PER_USER= # OPTIONAL
# Skills: auto-evolve trust threshold (0-1) before a skill self-updates (skills/types.ts).
PA_SKILLS_AUTO_EVOLVE_TRUST_THRESHOLD=       # OPTIONAL
# Skills: max skills loaded into context per run (skills/types.ts).
PA_SKILLS_MAX_LOADED_PER_RUN=                # OPTIONAL
# Stripe connector: max write actions per minute (connectors/stripe/index.ts).
PA_STRIPE_MAX_WRITES_PER_MIN=                # OPTIONAL
# Zoom connector: max write actions per minute (connectors/zoom/index.ts).
PA_ZOOM_MAX_WRITES_PER_MIN=                  # OPTIONAL

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS — string "true" turns the feature ON; anything else is OFF.
# All OPTIONAL; default OFF.
# ═══════════════════════════════════════════════════════════════════════════

# Make the chat surface the app home (chat/feature-flag.ts).
PA_CHAT_AS_HOME=                             # OPTIONAL — "true" to enable
# Enable Moonchild URL-import in the Landing Page Builder (also needs MOONCHILD_MCP_*).
PA_MOONCHILD_URL_IMPORT_ENABLED=             # OPTIONAL — "true" to enable
# Master switch for the agent orchestrator (orchestrator/feature-flag.ts).
PA_ORCHESTRATOR_ENABLED=                     # OPTIONAL — "true" to enable
# Enable orchestrator project gates / budget enforcement (gates/config.ts).
PA_PROJECT_GATES_ENABLED=                    # OPTIONAL — "true" to enable

# ═══════════════════════════════════════════════════════════════════════════
# EMAILS — sender domains, footer, and unsubscribe signing.
# ═══════════════════════════════════════════════════════════════════════════

# CAN-SPAM physical address printed in email footers (emails/render.ts).
EMAIL_PHYSICAL_ADDRESS=                      # OPTIONAL — has a default address
# HMAC secret signing one-click unsubscribe links in the queued email system
# (emails/render.ts). REQUIRED in prod — the dev default must not ship live.
EMAIL_UNSUBSCRIBE_SECRET=                    # REQUIRED
# HMAC secret for the legacy unsubscribe-token path (lib/unsubscribe-token.ts).
UNSUBSCRIBE_SECRET=                          # REQUIRED
# Domain for per-owner BCC capture addresses (inbound-email/parse.ts).
PA_BCC_EMAIL_DOMAIN=                         # OPTIONAL — defaults to bcc.aipocketagent.com
# Domain for inbound-email capture addresses (inbound-email/parse.ts).
PA_INBOUND_EMAIL_DOMAIN=                     # OPTIONAL — defaults to inbound.aipocketagent.com

# ═══════════════════════════════════════════════════════════════════════════
# OPERATIONS / FULFILLMENT — operator routing + downloadable kit storage.
# ═══════════════════════════════════════════════════════════════════════════

# Comma-separated operator emails that receive Setup Sprint / DWY fulfillment
# notifications and gate the operator console (lib/operator.ts).
PA_OPERATOR_EMAILS=                          # OPTIONAL
# Booking URL printed in Setup Sprint calendar invites (setup-sprint/...).
SETUP_SPRINT_BOOKING_URL=                    # OPTIONAL — defaults to /setup-sprint/book
# Supabase Storage bucket holding the DIY Kit PDF for signed downloads (diy-kit/download.ts).
DIY_KIT_BUNDLE_BUCKET=                       # OPTIONAL — defaults to "downloads"
# Object path within that bucket for the DIY Kit PDF (diy-kit/download.ts).
DIY_KIT_BUNDLE_PATH=                         # OPTIONAL — has a default path

# ═══════════════════════════════════════════════════════════════════════════
# WEBINAR FUNNEL — live-session timing + join/replay URLs (lib/webinar/config.ts).
# ═══════════════════════════════════════════════════════════════════════════

# ISO timestamp of the next live webinar session — anchors the email schedule.
WEBINAR_NEXT_SESSION_AT=                     # OPTIONAL
# Live webinar join URL (falls back to the on-site /replay).
WEBINAR_JOIN_URL=                            # OPTIONAL
# Webinar replay video URL shown on /replay (falls back to /replay).
WEBINAR_REPLAY_URL=                          # OPTIONAL

# ═══════════════════════════════════════════════════════════════════════════
# BRANDING / PUBLIC URLS — public-facing links baked into pages + emails.
# ═══════════════════════════════════════════════════════════════════════════

# Public site origin used to build magic links, the iOS Shortcut, etc.
NEXT_PUBLIC_SITE_URL=                        # OPTIONAL — defaults to https://aipocketagent.com
# Skool community URL linked across the app + emails (constants/skool.ts).
NEXT_PUBLIC_SKOOL_URL=                       # OPTIONAL — defaults to the public Skool URL

# ═══════════════════════════════════════════════════════════════════════════
# MISC RUNTIME
# ═══════════════════════════════════════════════════════════════════════════

# Explicit Chromium binary path for headless URL extraction (url-extraction/browser.ts).
# Set on hosts where the bundled/auto-detected Chromium isn't found.
PA_CHROMIUM_EXECUTABLE=                      # OPTIONAL
