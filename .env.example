# ── Auth / public Supabase (bos-internal project, repointed by env in Vercel) ──
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Pocket Agent Supabase (dedicated PA project — separate from bos-internal CRM) ──
# When these are set they take precedence over NEXT_PUBLIC_SUPABASE_* for all
# Pocket Agent data access (pa-supabase, pa-conversations, pocket-agent-supabase,
# middleware subscription check, billing-portal route).  Leave unset to fall back
# to the existing chain (safe during the cutover rollout).
POCKET_AGENT_SUPABASE_URL=https://<pa-project>.supabase.co
POCKET_AGENT_SUPABASE_ANON_KEY=<pa-anon-key>
POCKET_AGENT_SUPABASE_SERVICE_KEY=<pa-service-role-key>

# ── CRM / leads Supabase (bos-internal — wc-admin-supabase.ts, do NOT repoint) ──
WC_ADMIN_SUPABASE_URL=https://<bos-internal>.supabase.co
WC_ADMIN_SUPABASE_SERVICE_KEY=<service-role-key>

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Pocket Agent recurring price (set explicitly as the checkout line item — NOT the
# product default_price). [2026-06-02 — repriced from $97/mo to $37/mo]
STRIPE_POCKET_AGENT_PRICE_ID=price_1TdyfmJ6S5nx9HK5EeAZQEPj

# ── OpenAI (Whisper speech-to-text for voice-memo capture) ──
# Used by POST /api/app/voice/transcribe to transcribe in-app voice memos via the
# whisper-1 audio/transcriptions endpoint (direct REST, no SDK). APA-provided key
# (not BYO) — set this in Vercel project env vars for all environments.
OPENAI_API_KEY=sk-...

# ── Connections v1 — Gmail OAuth + 5-min cron sync ──
# Web OAuth client (Chase provisions in GCP console). Redirect URIs:
#   https://app.aipocketagency.com/api/connections/gmail/callback  (prod)
#   http://localhost:3000/api/connections/gmail/callback           (dev)
# Scopes: gmail.readonly + gmail.modify + gmail.labels (+ openid, email).
GMAIL_OAUTH_CLIENT_ID=<gmail-oauth-client-id>
GMAIL_OAUTH_CLIENT_SECRET=<gmail-oauth-client-secret>
# Single source of truth for the OAuth redirect_uri (lib/gmail.ts gmailRedirectUri()).
# MUST match a registered Authorized redirect URI origin in the GCP OAuth client, or
# Google fails the flow with "Error 400: redirect_uri_mismatch". Never derived from
# the request host (prod also answers on the apex + *.vercel.app aliases).
#   prod + dev (Vercel): https://app.aipocketagency.com
#   local:               http://localhost:3000
PA_OAUTH_REDIRECT_BASE=https://app.aipocketagency.com
# 32-byte base64 key encrypting stored Gmail refresh tokens (AES-256-GCM,
# lib/crypto/encrypt.ts). Generate fresh: openssl rand -base64 32
GMAIL_TOKEN_ENCRYPTION_KEY=<base64-32-bytes>
# Shared secret the Vercel cron sends as `Authorization: Bearer`. Also gates
# /api/cron/routines. Generate: openssl rand -hex 32
CRON_SECRET=<cron-secret>
