{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/apa/drip/sweep",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/routines",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.aipocketagency.com" }],
      "destination": "/app/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.aipocketagent.com" }],
      "destination": "https://aipocketagent.com/:path*",
      "permanent": true
    }
  ]
}
