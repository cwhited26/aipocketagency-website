{
  "name": "pa-capture-mac",
  "productName": "Pocket Agent Capture",
  "version": "0.1.0",
  "description": "Menu-bar app that auto-captures clipboard + screenshots and syncs them to your Pocket Agent brain.",
  "author": "Chase Whited <cwhited94@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "gen:icons": "node scripts/gen-icons.mjs",
    "copy:assets": "node scripts/copy-assets.mjs",
    "compile": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json",
    "build": "npm run clean && npm run compile && npm run copy:assets",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac",
    "dist:universal": "npm run build && electron-builder --mac --universal"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "better-sqlite3": "^11.10.0",
    "electron-log": "^5.2.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.aipocketagency.capture",
    "productName": "Pocket Agent Capture",
    "copyright": "Copyright © 2026 AI Pocket Agency",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSAppleEventsUsageDescription": "Pocket Agent Capture reads the name of the frontmost app so you can allow/deny capture per application.",
        "NSScreenCaptureUsageDescription": "Pocket Agent Capture watches your Screenshots and Desktop folders for new screenshots to capture."
      }
    },
    "dmg": {
      "title": "Pocket Agent Capture ${version}"
    }
  }
}
